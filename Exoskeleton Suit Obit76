SECTION 20 — JETSON MOTION DETECTION + COMMAND (50Hz)
============================================================

import time
import serial
import math

# SERIAL CONNECTION TO STM32
ser = serial.Serial('/dev/ttyUSB0', 115200)

# ==== IMU PLACEHOLDER (REPLACE WITH REAL SENSOR) ====
def read_imu():
    angle = 0.0
    velocity = 0.0
    return angle, velocity

# ==== MOTION DETECTION ====
def detect_motion(angle, velocity):
    if velocity > 0.5:
        return "EXTENSION"
    elif velocity < -0.5:
        return "FLEXION"
    else:
        return "IDLE"

# ==== TORQUE GENERATION ====
def compute_torque(state, velocity):
    if state == "EXTENSION":
        return min(10.0, velocity * 5.0)
    elif state == "FLEXION":
        return -min(8.0, abs(velocity * 4.0))
    else:
        return 0.0

# ==== COMMUNICATION ====
def send_command(torque):
    msg = f"{torque:.2f}\n"
    ser.write(msg.encode())

def send_heartbeat():
    ser.write(b"H\n")

# ==== MAIN LOOP (50Hz) ====
while True:
    angle, velocity = read_imu()

    state = detect_motion(angle, velocity)
    torque = compute_torque(state, velocity)

    send_command(torque)
    send_heartbeat()

    time.sleep(0.02)

