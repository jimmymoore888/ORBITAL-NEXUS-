SECTION 19 — STM32 REAL-TIME CONTROL LOOP (1kHz)
============================================================

#include <math.h>
#include <stdbool.h>

// ==== GLOBALS ====
float target_torque = 0.0f;
float current_torque = 0.0f;
float joint_angle = 0.0f;
float joint_velocity = 0.0f;

float Kp = 2.0f;
float Kd = 0.1f;

float max_torque = 15.0f;     // SAFE LIMIT (Nm)
float max_velocity = 5.0f;    // rad/s

bool heartbeat_ok = false;
uint32_t last_heartbeat_time = 0;

// ==== HARDWARE INTERFACES (IMPLEMENT PER BOARD) ====
float read_encoder_angle();
float read_encoder_velocity();
float read_current();
void motor_set_torque(float torque);
uint32_t millis();
bool jetson_heartbeat_received();
float get_jetson_command();

// ==== MAIN CONTROL LOOP (RUN AT 1kHz) ====
void control_loop() {

    // --- HEARTBEAT CHECK ---
    if (jetson_heartbeat_received()) {
        heartbeat_ok = true;
        last_heartbeat_time = millis();
    }

    if (millis() - last_heartbeat_time > 200) {
        heartbeat_ok = false;
        motor_set_torque(0);
        return;
    }

    // --- SENSOR READ ---
    joint_angle = read_encoder_angle();
    joint_velocity = read_encoder_velocity();
    current_torque = read_current();

    // --- COMMAND INPUT ---
    float desired_torque = get_jetson_command();

    // --- SAFETY LIMITS ---
    if (fabs(joint_velocity) > max_velocity) {
        desired_torque = 0;
    }

    if (desired_torque > max_torque) {
        desired_torque = max_torque;
    }
    if (desired_torque < -max_torque) {
        desired_torque = -max_torque;
    }

    // --- PD CONTROL ---
    float error = desired_torque - current_torque;
    float control_output = (Kp * error) - (Kd * joint_velocity);

    // --- APPLY OUTPUT ---
    motor_set_torque(control_output);
}

