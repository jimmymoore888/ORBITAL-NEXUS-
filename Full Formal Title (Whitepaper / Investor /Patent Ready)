import torch
import torchvision.transforms as T
import cv2

model = torch.jit.load("terrain_model.pt").eval().to("cuda")

transform = T.Compose([
    T.ToPILImage(),
    T.Resize((224,224)),
    T.ToTensor(),
])

def classify_frame(frame_bgr):
    img = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB)
    x = transform(img).unsqueeze(0).to("cuda")
    with torch.no_grad():
        logits = model(x)
        probs = torch.softmax(logits, dim=1)
    conf, cls = torch.max(probs, dim=1)
    return int(cls.item()), float(conf.item())

