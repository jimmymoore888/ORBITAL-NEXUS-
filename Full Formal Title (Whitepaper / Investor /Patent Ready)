SECTION 22.3 — STM32 EKF (CONTROL-GRADE, 500–1000 Hz)
------------------------------------------------------------

STATE VECTOR x:
[ theta_knee, omega_knee, torque_est, contact_flag ]

INPUTS u:
[ motor_current, commanded_torque ]

MEASUREMENTS z:
[ encoder_angle, encoder_velocity, foot_pressure_sum, imu_pitch_rate ]

MODEL (DISCRETE):
theta_k+1 = theta_k + omega_k * dt
omega_k+1 = omega_k + (torque_est / J) * dt
torque_est_k+1 = alpha * motor_current   // linear map
contact_flag_k+1 = f(pressure)

PROCESS NOISE Q:
diag([1e-5, 1e-3, 1e-2, 1e-2])

MEASUREMENT NOISE R:
diag([1e-4, 1e-3, 1e-2, 1e-2])

--- C-LIKE PSEUDO IMPLEMENTATION ---

typedef struct {
    float x[4];     // state
    float P[4][4];  // covariance
} EKF;

void ekf_predict(EKF* ekf, float dt) {
    float theta = ekf->x[0];
    float omega = ekf->x[1];
    float torque = ekf->x[2];

    ekf->x[0] = theta + omega * dt;
    ekf->x[1] = omega + (torque / J) * dt;
    // torque updated in update step

    // P = F P F^T + Q (implement minimal 4x4 multiply)
}

void ekf_update(EKF* ekf,
                float z_theta,
                float z_omega,
                float z_pressure,
                float z_imu_rate) {

    // Measurement vector z = [theta, omega, contact, imu_rate]
    // H = identity (simplified for V1)

    float y[4];
    y[0] = z_theta  - ekf->x[0];
    y[1] = z_omega  - ekf->x[1];
    y[2] = z_pressure - ekf->x[3];
    y[3] = z_imu_rate - ekf->x[1];

    // K = P (P + R)^-1  (approximate with diagonal for V1)
    for (int i=0;i<4;i++){
        float S = ekf->P[i][i] + R[i];
        float K = ekf->P[i][i] / S;
        ekf->x[i] += K * y[i];
        ekf->P[i][i] *= (1.0f - K);
    }

    // contact flag from pressure threshold
    ekf->x[3] = (z_pressure > PRESSURE_THR) ? 1.0f : 0.0f;
}

